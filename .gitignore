# Ignore Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Ignore pytest cache
.pytest_cache/

# Ignore reports (keep directory but not files)
reports/*.html
reports/*.json

# Ignore virtual environments
venv/
env/
ENV/

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore logs
*.log
